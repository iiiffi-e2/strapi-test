    "sidebarPrimaryCtaHref": {
      "type": "string"
    },
    "sidebarSecondaryCtaLabel": {
      "type": "string"
    },
    "sidebarSecondaryCtaHref": {
      "type": "string"
    },
    "servicesEyebrow": {
      "type": "string"
    },
    "servicesHeadingPrefix": {
      "type": "string"
    },
    "servicesHeadingEmphasis": {
      "type": "string"
    },
    "locationServices": {
      "type": "component",
      "repeatable": true,
      "component": "hospital.location-service"
    },
    "teamEyebrow": {
      "type": "string"
    },
    "teamHeadingPrefix": {
      "type": "string"
    },
    "teamHeadingEmphasis": {
      "type": "string"
    },
    "teamMembers": {
      "type": "component",
      "repeatable": true,
      "component": "hospital.team-member"
    },
    "admissionsEyebrow": {
      "type": "string"
    },
    "admissionsHeadingPrefix": {
      "type": "string"
    },
    "admissionsHeadingEmphasis": {
      "type": "string"
    },
